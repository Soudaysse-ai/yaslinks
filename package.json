    "qrcode": "^1.5.4",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
