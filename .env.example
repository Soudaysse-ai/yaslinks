# ─── DATABASE ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Providers: Neon (neon.tech), Supabase, Railway, PlanetScale
DATABASE_URL=postgresql://user:password@host:5432/yas_links

# ─── SESSION ───────────────────────────────────────────────────────────────────
# Secret used to sign session cookies — must be long and random
# Generate one: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-secret

# ─── SERVER ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── FRONTEND (build-time) ─────────────────────────────────────────────────────
# URL where your backend is deployed (Railway, Render, Fly.io, etc.)
# Leave empty for local dev — Vite proxy handles /api automatically
VITE_API_URL=https://your-backend.railway.app
